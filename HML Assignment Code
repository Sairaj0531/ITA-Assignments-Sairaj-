      "source": [
        "# ============================================================\n",
        "#   HYBRID MACHINE LEARNING PIPELINE - HATE SPEECH DETECTION\n",
        "#   Unsupervised (K-Means) + Supervised (Random Forest)\n",
        "#   Compatible with Google Colab & Jupyter Notebook\n",
        "# ============================================================\n",
        "\n",
        "# ── STEP 0: INSTALL REQUIRED LIBRARIES (Run this first in Colab) ──\n",
        "# Uncomment and run the line below if wordcloud is not installed:\n",
        "# !pip install wordcloud --quiet\n",
        "\n",
        "\n",
        "# ── STEP 1: IMPORT LIBRARIES ─────────────────────────────────\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import re\n",
        "import io\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.gridspec as gridspec\n",
        "import seaborn as sns\n",
        "\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.metrics import classification_report, confusion_matrix\n",
        "from sklearn.manifold import TSNE\n",
        "\n",
        "from wordcloud import WordCloud\n",
        "from nltk.corpus import stopwords\n",
        "import nltk\n",
        "\n",
        "nltk.download(\"stopwords\", quiet=True)\n",
        "\n",
        "\n",
        "# ── STEP 2: UPLOAD DATASET ───────────────────────────────────\n",
        "# This uses Google Colab's built-in file upload dialog.\n",
        "# When you run this cell, a \"Choose File\" button will appear.\n",
        "# Click it and select your labeled_data.csv file.\n",
        "\n",
        "print(\"   Please upload your 'labeled_data.csv' file to continue...\\n\")\n",
        "\n",
        "from google.colab import files          # Works in Google Colab only\n",
        "uploaded = files.upload()               # Opens the upload dialog\n",
        "\n",
        "# Automatically read whichever file was uploaded\n",
        "filename = list(uploaded.keys())[0]\n",
        "df = pd.read_csv(io.BytesIO(uploaded[filename]))\n",
        "\n",
        "print(f\"\\n✅ '{filename}' uploaded and loaded successfully!\")\n",
        "print(f\"   Dataset shape: {df.shape}\")\n",
        "print(df.head(3))\n",
        "\n",
        "\n",
        "# ── STEP 3: PREPROCESSING ────────────────────────────────────\n",
        "\n",
        "# Drop the index/count column if it exists\n",
        "if \"count\" in df.columns:\n",
        "    df.drop(columns=[\"count\"], inplace=True)\n",
        "\n",
        "# Keep only the columns we need\n",
        "df = df[[\"tweet\", \"class\"]].dropna().reset_index(drop=True)\n",
        "\n",
        "# Map numeric class labels to readable names\n",
        "label_map = {0: \"Hate Speech\", 1: \"Offensive\", 2: \"Neutral\"}\n",
        "df[\"label\"] = df[\"class\"].map(label_map)\n",
        "\n",
        "# Load English stopwords\n",
        "STOP_WORDS = set(stopwords.words(\"english\"))\n",
        "\n",
        "def clean_tweet(text):\n",
        "    \"\"\"\n",
        "    Cleans a single tweet by:\n",
        "    - Converting to lowercase\n",
        "    - Removing URLs, @mentions, hashtags\n",
        "    - Removing punctuation and special characters\n",
        "    - Removing stopwords and very short words\n",
        "    \"\"\"\n",
        "    text = str(text).lower()\n",
        "    text = re.sub(r\"http\\S+|www\\S+\", \"\", text)        # Remove URLs\n",
        "    text = re.sub(r\"@\\w+\", \"\", text)                   # Remove @mentions\n",
        "    text = re.sub(r\"#\\w+\", \"\", text)                   # Remove #hashtags\n",
        "    text = re.sub(r\"[^a-z\\s]\", \"\", text)               # Remove non-alphabetic chars\n",
        "    text = re.sub(r\"\\s+\", \" \", text).strip()           # Remove extra whitespace\n",
        "    words = [w for w in text.split() if w not in STOP_WORDS and len(w) > 2]\n",
        "    return \" \".join(words)\n",
        "\n",
        "print(\"\\n🔄 Cleaning tweet text...\")\n",
        "df[\"clean_tweet\"] = df[\"tweet\"].apply(clean_tweet)\n",
        "print(\"✅ Preprocessing complete!\")\n",
        "\n",
        "\n",
        "# ── STEP 4: TF-IDF VECTORIZATION ─────────────────────────────\n",
        "# Converts cleaned text into numerical feature vectors\n",
        "\n",
        "print(\"\\n🔢 Applying TF-IDF Vectorization...\")\n",
        "\n",
        "tfidf = TfidfVectorizer(max_features=3000, ngram_range=(1, 2))\n",
        "X_tfidf = tfidf.fit_transform(df[\"clean_tweet\"])\n",
        "\n",
        "print(f\"✅ TF-IDF matrix created — Shape: {X_tfidf.shape}\")\n",
        "\n",
        "\n",
        "# ── STEP 5: UNSUPERVISED LEARNING — K-MEANS CLUSTERING ───────\n",
        "# Groups tweets into 3 clusters based on language similarity\n",
        "\n",
        "print(\"\\n🔵 Running K-Means Clustering (k=3)...\")\n",
        "\n",
        "kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)\n",
        "df[\"cluster\"] = kmeans.fit_predict(X_tfidf)\n",
        "\n",
        "print(\"✅ Clustering done!\")\n",
        "print(df[\"cluster\"].value_counts().rename(\"Tweet Count\"))\n",
        "\n",
        "\n",
        "# ── STEP 6: SUPERVISED LEARNING — RANDOM FOREST ──────────────\n",
        "# Trains a classifier to predict the label of each tweet\n",
        "\n",
        "print(\"\\n🟢 Training Random Forest Classifier...\")\n",
        "\n",
        "y = df[\"class\"]\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X_tfidf, y,\n",
        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=y          # Ensures equal class proportion in train/test\n",
        ")\n",
        "\n",
        "rf_model = RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)\n",
        "rf_model.fit(X_train, y_train)\n",
        "y_pred = rf_model.predict(X_test)\n",
        "\n",
        "print(\"✅ Training complete! Predictions generated.\")\n",
        "print(\"\\n📊 Classification Report:\")\n",
        "print(classification_report(\n",
        "    y_test, y_pred,\n",
        "    target_names=[\"Hate Speech\", \"Offensive\", \"Neutral\"]\n",
        "))\n",
        "\n",
        "\n",
        "# ── STEP 7: VISUALIZATIONS ───────────────────────────────────\n",
        "\n",
        "PALETTE   = [\"#E63946\", \"#F4A261\", \"#2A9D8F\"]    # Red, Orange, Teal\n",
        "FONT_BOLD = {\"fontsize\": 13, \"fontweight\": \"bold\"}\n",
        "BG_DARK   = \"#0F1117\"\n",
        "CARD_BG   = \"#1A1D27\"\n",
        "BORDER    = \"#3A3D4D\"\n",
        "\n",
        "fig = plt.figure(figsize=(22, 20))\n",
        "fig.patch.set_facecolor(BG_DARK)\n",
        "gs  = gridspec.GridSpec(3, 3, figure=fig, hspace=0.5, wspace=0.4)\n",
        "\n",
        "ax_class   = fig.add_subplot(gs[0, 0])    # A — Class distribution\n",
        "ax_cluster = fig.add_subplot(gs[0, 1])    # B — Cluster distribution\n",
        "ax_wc      = fig.add_subplot(gs[0, 2])    # C — Word cloud\n",
        "ax_cm      = fig.add_subplot(gs[1, 0])    # D — Confusion matrix\n",
        "ax_tsne    = fig.add_subplot(gs[1, 1:])   # E — t-SNE (spans 2 columns)\n",
        "ax_words   = fig.add_subplot(gs[2, :])    # F — Top words per class\n",
        "\n",
        "# Apply dark background to all axes\n",
        "for ax in fig.axes:\n",
        "    ax.set_facecolor(CARD_BG)\n",
        "    for spine in ax.spines.values():\n",
        "        spine.set_edgecolor(BORDER)\n",
        "\n",
        "\n",
        "# ── A) CLASS DISTRIBUTION BAR CHART ──────────────────────────\n",
        "class_counts = df[\"label\"].value_counts().reindex([\"Hate Speech\", \"Offensive\", \"Neutral\"])\n",
        "bars = ax_class.bar(class_counts.index, class_counts.values,\n",
        "                    color=PALETTE, edgecolor=BG_DARK, linewidth=1.5)\n",
        "for bar, val in zip(bars, class_counts.values):\n",
        "    ax_class.text(bar.get_x() + bar.get_width() / 2,\n",
        "                  bar.get_height() + 150,\n",
        "                  f\"{val:,}\", ha=\"center\", va=\"bottom\",\n",
        "                  color=\"white\", fontsize=10, fontweight=\"bold\")\n",
        "ax_class.set_title(\"📊 Class Distribution\", color=\"white\", **FONT_BOLD)\n",
        "ax_class.set_xlabel(\"Category\", color=\"#AAAAAA\")\n",
        "ax_class.set_ylabel(\"Number of Tweets\", color=\"#AAAAAA\")\n",
        "ax_class.tick_params(colors=\"white\")\n",
        "\n",
        "\n",
        "# ── B) CLUSTER DISTRIBUTION BAR CHART ────────────────────────\n",
        "cluster_counts  = df[\"cluster\"].value_counts().sort_index()\n",
        "cluster_labels  = [f\"Cluster {i}\" for i in cluster_counts.index]\n",
        "cluster_colors  = [\"#6A0572\", \"#1A78C2\", \"#FF6B35\"]\n",
        "bars2 = ax_cluster.bar(cluster_labels, cluster_counts.values,\n",
        "                        color=cluster_colors, edgecolor=BG_DARK, linewidth=1.5)\n",
        "for bar, val in zip(bars2, cluster_counts.values):\n",
        "    ax_cluster.text(bar.get_x() + bar.get_width() / 2,\n",
        "                    bar.get_height() + 100,\n",
        "                    f\"{val:,}\", ha=\"center\", va=\"bottom\",\n",
        "                    color=\"white\", fontsize=10, fontweight=\"bold\")\n",
        "ax_cluster.set_title(\"🔵 K-Means Cluster Distribution\", color=\"white\", **FONT_BOLD)\n",
        "ax_cluster.set_xlabel(\"Cluster\", color=\"#AAAAAA\")\n",
        "ax_cluster.set_ylabel(\"Number of Tweets\", color=\"#AAAAAA\")\n",
        "ax_cluster.tick_params(colors=\"white\")\n",
        "\n",
        "\n",
        "# ── C) WORD CLOUD ─────────────────────────────────────────────\n",
        "all_text = \" \".join(df[\"clean_tweet\"].values)\n",
        "wc = WordCloud(\n",
        "    width=600, height=350,\n",
        "    background_color=CARD_BG,\n",
        "    colormap=\"RdYlGn\",\n",
        "    max_words=120,\n",
        "    contour_color=BORDER,\n",
        "    contour_width=1\n",
        ").generate(all_text)\n",
        "ax_wc.imshow(wc, interpolation=\"bilinear\")\n",
        "ax_wc.axis(\"off\")\n",
        "ax_wc.set_title(\"☁️ Word Cloud — Common Terms\", color=\"white\", **FONT_BOLD)\n",
        "\n",
        "\n",
        "# ── D) CONFUSION MATRIX HEATMAP ───────────────────────────────\n",
        "cm = confusion_matrix(y_test, y_pred)\n",
        "sns.heatmap(\n",
        "    cm, annot=True, fmt=\"d\", cmap=\"YlOrRd\",\n",
        "    xticklabels=[\"Hate Speech\", \"Offensive\", \"Neutral\"],\n",
        "    yticklabels=[\"Hate Speech\", \"Offensive\", \"Neutral\"],\n",
        "    ax=ax_cm, linewidths=0.5, linecolor=BG_DARK,\n",
        "    cbar_kws={\"shrink\": 0.8}\n",
        ")\n",
        "ax_cm.set_title(\"🔥 Confusion Matrix\", color=\"white\", **FONT_BOLD)\n",
        "ax_cm.set_xlabel(\"Predicted Label\", color=\"#AAAAAA\")\n",
        "ax_cm.set_ylabel(\"True Label\", color=\"#AAAAAA\")\n",
        "ax_cm.tick_params(colors=\"white\")\n",
        "plt.setp(ax_cm.get_xticklabels(), color=\"white\")\n",
        "plt.setp(ax_cm.get_yticklabels(), color=\"white\")\n",
        "\n",
        "\n",
        "# ── E) t-SNE CLUSTER VISUALIZATION ───────────────────────────\n",
        "print(\"\\n⏳ Running t-SNE — this may take 1–2 minutes...\")\n",
        "\n",
        "sample_size    = min(2000, X_tfidf.shape[0])\n",
        "sample_idx     = np.random.choice(X_tfidf.shape[0], sample_size, replace=False)\n",
        "X_sample       = X_tfidf[sample_idx].toarray()\n",
        "cluster_sample = df[\"cluster\"].values[sample_idx]\n",
        "\n",
        "tsne = TSNE(n_components=2, random_state=42, perplexity=30, n_iter=300)\n",
        "X_2d = tsne.fit_transform(X_sample)\n",
        "\n",
        "tsne_colors = [\"#6A0572\", \"#1A78C2\", \"#FF6B35\"]\n",
        "for cid, (color, clabel) in enumerate(zip(tsne_colors, [\"Cluster 0\", \"Cluster 1\", \"Cluster 2\"])):\n",
        "    mask = cluster_sample == cid\n",
        "    ax_tsne.scatter(X_2d[mask, 0], X_2d[mask, 1],\n",
        "                    c=color, label=clabel, alpha=0.6, s=10, edgecolors=\"none\")\n",
        "\n",
        "ax_tsne.set_title(\"🌐 t-SNE — Tweet Cluster Visualization\", color=\"white\", **FONT_BOLD)\n",
        "ax_tsne.set_xlabel(\"t-SNE Dimension 1\", color=\"#AAAAAA\")\n",
        "ax_tsne.set_ylabel(\"t-SNE Dimension 2\", color=\"#AAAAAA\")\n",
        "ax_tsne.tick_params(colors=\"white\")\n",
        "ax_tsne.legend(facecolor=CARD_BG, labelcolor=\"white\", fontsize=10)\n",
        "\n",
        "\n",
        "# ── F) TOP TF-IDF WORDS PER CLASS ────────────────────────────\n",
        "feature_names = np.array(tfidf.get_feature_names_out())\n",
        "class_ids     = [0, 1, 2]\n",
        "class_names   = [\"Hate Speech\", \"Offensive Language\", \"Neutral\"]\n",
        "\n",
        "x_offset  = 0\n",
        "bar_width = 0.6\n",
        "group_gap = 12\n",
        "\n",
        "for cls_id, cls_name, color in zip(class_ids, class_names, PALETTE):\n",
        "    indices    = df[df[\"class\"] == cls_id].index\n",
        "    sub_tfidf  = X_tfidf[indices]\n",
        "    mean_score = np.asarray(sub_tfidf.mean(axis=0)).flatten()\n",
        "    top10_idx  = mean_score.argsort()[-10:][::-1]\n",
        "    top_words  = feature_names[top10_idx]\n",
        "    top_scores = mean_score[top10_idx]\n",
        "\n",
        "    x_positions = np.arange(x_offset, x_offset + 10)\n",
        "    ax_words.bar(x_positions, top_scores, width=bar_width,\n",
        "                 color=color, edgecolor=BG_DARK, linewidth=0.8, label=cls_name)\n",
        "\n",
        "    for xp, word in zip(x_positions, top_words):\n",
        "        ax_words.text(xp, -0.0005, word, ha=\"center\", va=\"top\",\n",
        "                      color=\"white\", fontsize=7.5, rotation=35)\n",
        "\n",
        "    ax_words.text(x_offset + 4.5, max(top_scores) * 1.05,\n",
        "                  cls_name, ha=\"center\", color=color, fontsize=10, fontweight=\"bold\")\n",
        "\n",
        "    x_offset += 10 + group_gap\n",
        "\n",
        "ax_words.set_title(\"🔑 Top TF-IDF Words per Class\", color=\"white\", **FONT_BOLD)\n",
        "ax_words.set_ylabel(\"Mean TF-IDF Score\", color=\"#AAAAAA\")\n",
        "ax_words.tick_params(colors=\"white\", labelbottom=False)\n",
        "ax_words.legend(facecolor=CARD_BG, labelcolor=\"white\", fontsize=9)\n",
        "\n",
        "\n",
        "# ── SAVE & DISPLAY ────────────────────────────────────────────\n",
        "plt.suptitle(\n",
        "    \"Hate Speech Detection — Hybrid ML Analysis\",\n",
        "    color=\"white\", fontsize=17, fontweight=\"bold\", y=1.01\n",
        ")\n",
        "\n",
        "output_path = \"hate_speech_analysis.png\"\n",
        "plt.savefig(output_path, dpi=150, bbox_inches=\"tight\", facecolor=fig.get_facecolor())\n",
        "print(f\"\\n✅ All visualizations saved to '{output_path}'\")\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n🏁 Pipeline complete! All steps finished successfully.\")"
